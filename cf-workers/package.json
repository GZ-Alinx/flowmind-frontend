{
  "name": "flowmind-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "db:init": "wrangler d1 execute flowmind-db --file=./schema.sql --local",
    "db:init:remote": "wrangler d1 execute flowmind-db --file=./schema.sql --remote",
    "db:reset": "wrangler d1 execute flowmind-db --file=./schema.sql --remote --force",
    "tail": "wrangler tail",
    "tail:prod": "wrangler tail --env production"
  },
  "dependencies": {
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250401.0",
    "wrangler": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
